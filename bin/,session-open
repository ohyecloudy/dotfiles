#!/bin/bash

set -x

is_windows() {
    case "$(uname -s)" in
        MINGW*|MSYS*|CYGWIN*) return 0 ;;
        *) return 1 ;;
    esac
}

show_whale() {
    cat << 'EOF'

        .
       ":"
     ___:____     |"\/"|
   ,'        `.    \  /
   |  O        \___/  |
 ~^~^~^~^~^~^~^~^~^~^~^~^~

   Oops! Something went wrong...

EOF
}

trap 'show_whale' ERR
set -e

cd ~/.dotfiles
git pull

# error code 1 is returned even during successful updating doom in Windows
doom install --force || true
doom sync || true
doom env || true

cd ~/org_roam
git pull

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if is_windows && [ -x "$SCRIPT_DIR/session-open-windows" ]; then
    "$SCRIPT_DIR/session-open-windows"
fi
